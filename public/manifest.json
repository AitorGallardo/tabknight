{
  "manifest_version": 3,
  "name": "TabKnight",
  "version": "1.0.0",
  "description": "Keyboard-first Chrome extension for tab management",
  "permissions": [
    "tabs",
    "bookmarks",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TabKnight"
  },
  "background": {
    "service_worker": "index.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
