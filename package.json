{
  "name": "tabknight",
  "version": "0.34.2",
  "description": "Chrome extension to save open tabs as bookmarks",
  "type": "module",
  "scripts": {
    "dev": "bun run config/build.ts --watch",
    "build": "bun run config/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:lifecycle": "bun test tests/invocation-lifecycle.test.ts",
    "smoke": "bun scripts/smoke.ts",
    "smoke:commands": "bun scripts/browser-commands-smoke.ts",
    "package": "bun scripts/package.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.312.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17"
  }
}
